rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isFriendOf(ownerId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(ownerId))
        && get(/databases/$(database)/documents/users/$(ownerId)).data.friendsList is list
        && get(/databases/$(database)/documents/users/$(ownerId)).data.friendsList.hasAny([request.auth.uid]);
    }

    // ── USERS ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();

      // Any signed-in user can create their own profile document.
      allow create: if isSignedIn()
        && request.auth.uid == userId;

      // Owner can update their own doc freely.
      // Another user may update the doc ONLY for friendsList changes
      // (friend request accept/reject/remove).  Profile fields are
      // restricted to the owner to prevent identity spoofing.
      // Immutable fields (uid, email, createdAt) must never change.
      allow update: if isSignedIn()
        && (!request.resource.data.keys().hasAny(['uid'])
            || request.resource.data.uid == resource.data.uid)
        && (!request.resource.data.keys().hasAny(['email'])
            || request.resource.data.email == resource.data.email)
        && (!request.resource.data.keys().hasAny(['createdAt'])
            || request.resource.data.createdAt == resource.data.createdAt)
        // Profile fields: ONLY the owner may modify them
        && (request.auth.uid == userId
            || !request.resource.data.keys().hasAny([
                 'name', 'bio', 'age', 'gender', 'country',
                 'profilePicUrl', 'coverPicUrl',
                 'isOnline', 'lastSeen']));
    }

    // ── FRIEND REQUESTS ───────────────────────────────────────────────
    match /friendRequests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == 'pending';

      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.receiverId
            || request.auth.uid == resource.data.senderId);

      // Receiver may accept or reject (delete).  We only validate the
      // status transition; immutable fields are checked only if present.
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.receiverId
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'rejected']
        && (!request.resource.data.keys().hasAny(['senderId'])
            || request.resource.data.senderId == resource.data.senderId)
        && (!request.resource.data.keys().hasAny(['receiverId'])
            || request.resource.data.receiverId == resource.data.receiverId);

      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.receiverId
            || request.auth.uid == resource.data.senderId);
    }

    // ── POSTS ─────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.userName is string
        && request.resource.data.likesCount is int
        && request.resource.data.dislikesCount is int
        && request.resource.data.comments is list
        && request.resource.data.userReactions is map
        && request.resource.data.createdAt is timestamp;

      // Owner can fully edit their post.
      // Friends (or any signed-in user) can toggle likes / dislikes and
      // add comments – but only non-immutable fields.
      allow update: if isSignedIn()
        && (
          // ── Owner of the post ──
          request.auth.uid == resource.data.userId
          || isFriendOf(resource.data.userId)
        )
        && (!request.resource.data.keys().hasAny(['userId'])
            || request.resource.data.userId == resource.data.userId)
        && (!request.resource.data.keys().hasAny(['userName'])
            || request.resource.data.userName == resource.data.userName)
        && (!request.resource.data.keys().hasAny(['userAvatar'])
            || request.resource.data.userAvatar == resource.data.userAvatar)
        && (!request.resource.data.keys().hasAny(['userCover'])
            || request.resource.data.userCover == resource.data.userCover)
        && (!request.resource.data.keys().hasAny(['createdAt'])
            || request.resource.data.createdAt == resource.data.createdAt)
        && (!request.resource.data.keys().hasAny(['text'])
            || request.resource.data.text is string)
        && (!request.resource.data.keys().hasAny(['likesCount'])
            || request.resource.data.likesCount is int)
        && (!request.resource.data.keys().hasAny(['dislikesCount'])
            || request.resource.data.dislikesCount is int)
        && (!request.resource.data.keys().hasAny(['comments'])
            || request.resource.data.comments is list)
        && (!request.resource.data.keys().hasAny(['userReactions'])
            || request.resource.data.userReactions is map);

      allow delete: if isSignedIn()
        && request.auth.uid == resource.data.userId;
    }

    // ── CHAT META ─────────────────────────────────────────────────────
    match /chatMeta/{chatId} {
      allow read: if isSignedIn();

      allow create, update: if isSignedIn()
        && (!request.resource.data.keys().hasAny(['lastSenderId'])
            || request.resource.data.lastSenderId is string)
        && (!request.resource.data.keys().hasAny(['lastMessageAt'])
            || request.resource.data.lastMessageAt is timestamp)
        && (!request.resource.data.keys().hasAny(['unreadFor'])
            || request.resource.data.unreadFor is map);

      allow delete: if false;
    }

    // ── CHAT MESSAGES ────────────────────────────────────────────────
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.timestamp is timestamp;
      allow update, delete: if false;
    }
  }
}